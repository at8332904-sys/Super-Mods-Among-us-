name: Gerar APK - Grande Anfitrião
on:
  push:
    branches: [ principal ]
  workflow_dispatch:

jobs:
  build-apk:
    runs-on: ubuntu-latest
    steps:
      - name: 1. Pegar todos os arquivos
        uses: actions/checkout@v4

      - name: 2. Preparar pasta do app
        run: |
          mkdir -p pacote_final/
          cp -r com.unity.addressables/ plugins/ codigos/ config_botao/ config.json miniatura.png pacote_final/
          rm -rf pacote_final/.git pacote_final/.github pacote_final/README.md

      - name: 3. Gerar APK com ferramenta válida
        uses: esafirm/android-build-action@v3
        with:
          project-path: pacote_final/
          output-name: Grande_Anfitriao.apk
          app-name: "Grande Anfitrião"
          package-name: "com.augusto.grandeanfitriao"
          min-sdk: 26
          target-sdk: 34
          icon-path: miniatura.png
          standalone-app: true

      - name: 4. Salvar APK pronto
        uses: actions/upload-artifact@v4
        with:
          name: APK_Final_Grande_Anfitriao
          path: "*.apk"



