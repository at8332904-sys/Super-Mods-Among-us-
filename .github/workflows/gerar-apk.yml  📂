name: Gerar APK - Grande Anfitrião
on:
  push:
    branches: [ principal ]
  workflow_dispatch:

jobs:
  build-apk:
    runs-on: ubuntu-latest
    steps:
      - name: 1. Pegar todos os arquivos mais recentes
        uses: actions/checkout@v4

      - name: 2. Montar pacote completo
        run: |
          mkdir -p pacote_final/
          cp -r com.unity.addressables/ plugins/ codigos/ config_botao/ config.json miniatura.png pacote_final/
          rm -rf pacote_final/.git pacote_final/.github pacote_final/README.md

      - name: 3. Gerar APK (~25 MB)
        uses: sombra1304/action-apk-builder@v1
        with:
          caminho-projeto: pacote_final/
          nome-saida: Grande_Anfitriao.apk
          versao-min-android: 26
          nivel-compressao: 9
          tamanho-maximo-mb: 25

      - name: 4. Disponibilizar APK
        uses: actions/upload-artifact@v4
        with:
          nome-do-arquivo: APK_Atualizado_Grande_Anfitriao
          caminho: pacote_final/*.apk

